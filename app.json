{
   "expo": {
      "name": "4Do-app",
      "slug": "4Do-app",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icons/4do_icon_512.jpg",
      "userInterfaceStyle": "light",
      "splash": {
         "image": "./assets/icons/4do_icon_192.jpg",
         "resizeMode": "contain",
         "backgroundColor": "#F9FAFB"
      },
      "assetBundlePatterns": ["**/*"],
      "ios": {
         "supportsTablet": true,
         "bundleIdentifier": "com.drcode4do.app"
      },
      "android": {
         "adaptiveIcon": {
            "backgroundColor": "#E6F4FE",
            "foregroundImage": "./assets/images/android-icon-foreground.png",
            "backgroundImage": "./assets/images/android-icon-background.png",
            "monochromeImage": "./assets/images/android-icon-monochrome.png"
         },
         "package": "com.drcode4do.app"
      },
      "web": {
         "output": "static",
         "favicon": "./assets/icons/4do_favicon.png"
      },
      "plugins": [
         "expo-router",
         [
            "expo-splash-screen",
            {
               "image": "./assets/images/splash-icon.png",
               "imageWidth": 200,
               "resizeMode": "contain",
               "backgroundColor": "#ffffff",
               "dark": {
                  "backgroundColor": "#000000"
               }
            }
         ]
      ],
      "experiments": {
         "typedRoutes": true,
         "reactCompiler": true
      }
   }
}
